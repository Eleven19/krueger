{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "docs-site (Astro)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "docs", "run", "dev"],
      "port": 4321
    },
    {
      "name": "try-wasm-playground (SvelteKit/Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "sites/try-wasm", "run", "dev"],
      "port": 5173
    },
    {
      "name": "docs-site full (Astro + try-wasm prepared)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "docs", "run", "dev:full"],
      "port": 4321
    },
    {
      "name": "docs-site full (port 4322)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "docs", "run", "dev:full", "--", "--port", "4322"],
      "port": 4322
    }
  ]
}
