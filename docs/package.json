{
  "name": "@eleven19/krueger-docs",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "prepare:try-wasm": "cd .. && ./mill docs.prepareLocalDevSite",
    "dev:full": "npm run prepare:try-wasm && astro dev",
    "build:api": "cd .. && ./mill docs.writeToDocsPublic",
    "build:wasm": "cd .. && ./mill krueger.webapp-wasm.writeToWasmSite",
    "build:try-wasm": "cd ../sites/try-wasm && npm ci && npm run build",
    "stitch:try-wasm": "node scripts/stitch-try-wasm-dist.mjs",
    "build:full": "npm run build:api && npm run build:wasm && npm run build:try-wasm && npm run build && npm run stitch:try-wasm",
    "site:build": "npm run build:full",
    "test:build-orchestration": "node scripts/check-build-orchestration.mjs",
    "test:nav": "node scripts/check-nav.mjs",
    "test:playground-e2e": "node scripts/check-playground-e2e.mjs",
    "test:try-wasm-deploy-workflow": "node scripts/check-try-wasm-deploy-workflow.mjs",
    "test:webapp-wasm-browser": "node scripts/check-webapp-wasm-browser.mjs",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.0",
    "astro": "^6.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
