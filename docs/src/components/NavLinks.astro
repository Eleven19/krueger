---
/**
 * Shared primary-nav links used by the Starlight Header override
 * (`Header.astro`). The previous version included a "Try ▾" dropdown
 * with two playgrounds (Laminar/Scala.js and SvelteKit/WASM); the
 * Laminar entry has been removed and the SvelteKit playground at
 * `/krueger/try/` (sourced from `sites/try-wasm/`) is now the
 * canonical playground. The dropdown is therefore collapsed to a
 * single anchor.
 *
 * Active-route highlighting mirrors Header.astro: derived from
 * `Astro.url.pathname` after normalising trailing slashes, so
 * `/krueger/try` and `/krueger/try/` compare equal.
 */

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function norm(p: string): string {
    return p.replace(/\/+$/, '') || '/';
}

const pathname = norm(Astro.url.pathname);
const inTryWasm =
    pathname === norm(`${base}/try`) || pathname.startsWith(norm(`${base}/try/`));
---

<nav class="primary-nav" aria-label="Primary">
    <a
        class="nav-link"
        data-active={pathname === norm(`${base}/introduction`) ? 'true' : undefined}
        href={`${base}/introduction/`}>Docs</a
    >

    <a
        class="nav-link"
        data-active={inTryWasm ? 'true' : undefined}
        href={`${base}/try/`}>Try</a
    >

    <a
        class="nav-link"
        data-active={pathname.startsWith(norm(`${base}/api`)) ? 'true' : undefined}
        href={`${base}/api/`}>API</a
    >
</nav>

<style>
    .primary-nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        font-size: var(--sl-text-sm, 0.875rem);
    }

    .nav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35em;
        padding: 0.25rem 0.5rem;
        color: var(--sl-color-gray-2, #a4acbd);
        text-decoration: none;
        border-radius: 0.25rem;
        cursor: pointer;
        white-space: nowrap;
    }
    .nav-link:hover {
        color: var(--sl-color-white, #f7f7f7);
        background: var(--sl-color-gray-6, #2a2d35);
    }
    .nav-link[data-active='true'] {
        color: var(--sl-color-white, #f7f7f7);
        font-weight: 600;
    }
</style>
